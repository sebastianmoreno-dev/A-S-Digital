# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el .env real a git (ya est   en .gitignore).

#  ^t^` ^t^` Flask  ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^>
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

#  ^t^` ^t^` Base de datos (PostgreSQL en producci  n)  ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` >
DATABASE_URL=postgresql://asvertex_user:ASDigital-angelysebastian05@localhost/as_vertex

#  ^t^` ^t^` Redis (Flask-Limiter y futuras colas/cache)  ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^`
# Si se omite, la app usa almacenamiento en memoria del proceso
# (solo v  lido para desarrollo local de un solo proceso).
# REDIS_URL=redis://localhost:6379/0

#  ^t^` ^t^` Correo (Flask-Mail)  ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t>
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=tu-cuenta@gmail.com
MAIL_PASSWORD=una-app-password-de-gmail
MAIL_DEFAULT_SENDER=hola@asvertex.com
ADMIN_EMAIL=hola@asvertex.com

#  ^t^` ^t^` Rate limiting / bloqueo autom  tico de IPs  ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^`>
RATE_LIMIT_VIOLATIONS_BEFORE_BLOCK=3
RATE_LIMIT_BLOCK_HOURS=24

#  ^t^` ^t^` Login admin (fuerza bruta)  ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` >
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

#  ^t^` ^t^` Formulario de contacto (antibot)  ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^`>
CONTACT_MIN_SECONDS=5

#  ^t^` ^t^` Panel de administraci  n  ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t>
# Prefijo (secreto) del panel. Usa un valor dif  cil de adivinar para
# mantenerlo oculto de bots que prueban /admin. Ej: /gestion-a1b2c3d4
ADMIN_URL_PREFIX=/admin
# Puertas de entrada adicionales (coma-separadas) que redirigen a la de
# arriba. Ej: ADMIN_URL_ALIASES=/angel-panel,/otra-puerta
ADMIN_URL_ALIASES=/sebas-panel
ADMIN_URL_ALIASES=/angel-panel

#  ^t^` ^t^` Proxy / Cloudflare  ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^>
# N  mero de proxies de confianza delante de Flask (Cloudflare -> Nginx = 1).
TRUSTED_PROXY_COUNT=1

#  ^t^` ^t^` Seed inicial (scripts/seed.py)  ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^t^` ^>
# Las contrase  as viven SOLO aqu   (en el .env del servidor, fuera de git)
# y se convierten a hash argon2 al sembrar. Cambia los valores de ejemplo
# por claves fuertes reales antes de correr el seed.
#
# Opci  n A  ^`^t un solo admin (entrada sencilla, sin n  mero):
# ADMIN_SEED_EMAIL=admin@asvertex.com
# ADMIN_SEED_PASSWORD=cambia-esto-por-una-clave-fuerte
# ADMIN_SEED_NOMBRE=Administrador
#
# Opci  n B  ^`^t varios admins (entradas numeradas 1, 2, 3,  ^` ). El seed las
# lee en orden y se detiene en el primer n  mero sin _EMAIL. Puedes
# combinarlas con la entrada sencilla de arriba (no se duplican correos).
ADMIN_SEED_1_EMAIL=sebastian@asvertex.com
ADMIN_SEED_1_PASSWORD=Sbas17ASvertex
ADMIN_SEED_1_NOMBRE=Sebastian

ADMIN_SEED_2_EMAIL=angel@asvertex.com
ADMIN_SEED_2_PASSWORD=f4ll3n-4n63l/ASVertex
ADMIN_SEED_2_NOMBRE= Angel

