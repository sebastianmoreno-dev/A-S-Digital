# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el .env real a git (ya está en .gitignore).

# ── Flask ──────────────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# ── Base de datos (PostgreSQL en producción) ────────────────────────
DATABASE_URL=postgresql://usuario:password@localhost/as_vertex

# ── Redis (Flask-Limiter y futuras colas/cache) ─────────────────────
# Si se omite, la app usa almacenamiento en memoria del proceso
# (solo válido para desarrollo local de un solo proceso).
REDIS_URL=redis://localhost:6379/0

# ── Correo (Flask-Mail) ──────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=tu-cuenta@gmail.com
MAIL_PASSWORD=una-app-password-de-gmail
MAIL_DEFAULT_SENDER=hola@asvertex.com
ADMIN_EMAIL=hola@asvertex.com

# ── Rate limiting / bloqueo automático de IPs ───────────────────────
RATE_LIMIT_VIOLATIONS_BEFORE_BLOCK=3
RATE_LIMIT_BLOCK_HOURS=24

# ── Login admin (fuerza bruta) ──────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Formulario de contacto (antibot) ────────────────────────────────
CONTACT_MIN_SECONDS=5

# ── Panel de administración ─────────────────────────────────────────
# Prefijo (secreto) del panel. Usa un valor difícil de adivinar para
# mantenerlo oculto de bots que prueban /admin. Ej: /gestion-a1b2c3d4
ADMIN_URL_PREFIX=/admin
# Puertas de entrada adicionales (coma-separadas) que redirigen a la de
# arriba. Ej: ADMIN_URL_ALIASES=/angel-panel,/otra-puerta
ADMIN_URL_ALIASES=

# ── Proxy / Cloudflare ───────────────────────────────────────────────
# Número de proxies de confianza delante de Flask (Cloudflare -> Nginx = 1).
TRUSTED_PROXY_COUNT=1

# ── Seed inicial (scripts/seed.py) ──────────────────────────────────
# Las contraseñas viven SOLO aquí (en el .env del servidor, fuera de git)
# y se convierten a hash argon2 al sembrar. Cambia los valores de ejemplo
# por claves fuertes reales antes de correr el seed.
#
# Opción A — un solo admin (entrada sencilla, sin número):
# ADMIN_SEED_EMAIL=admin@asvertex.com
# ADMIN_SEED_PASSWORD=cambia-esto-por-una-clave-fuerte
# ADMIN_SEED_NOMBRE=Administrador
#
# Opción B — varios admins (entradas numeradas 1, 2, 3, …). El seed las
# lee en orden y se detiene en el primer número sin _EMAIL. Puedes
# combinarlas con la entrada sencilla de arriba (no se duplican correos).
ADMIN_SEED_1_EMAIL=sebastian@asvertex.com
ADMIN_SEED_1_PASSWORD=cambia-esto-por-una-clave-fuerte
ADMIN_SEED_1_NOMBRE=Sebastián

ADMIN_SEED_2_EMAIL=angel@asvertex.com
ADMIN_SEED_2_PASSWORD=


ADMIN_SEED_2_NOMBRE=Ángel
